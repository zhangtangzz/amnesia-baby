# ========== LLM 提供商配置 ==========
# 可选: xiaomi / openai / deepseek / qwen
LLM_PROVIDER=xiaomi
LLM_MODEL=mimo-v2.5-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_MAX_RETRIES=3

# ========== 小米 MIMO ==========
XIAOMI_API_KEY=your-api-key-here
XIAOMI_API_BASE=https://token-plan-cn.xiaomimimo.com/anthropic
XIAOMI_MODEL=mimo-v2.5-pro

# ========== OpenAI ==========
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# ========== DeepSeek ==========
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ========== 通义千问 ==========
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 应用配置 ==========
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
